root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,cjs,mjs}]
indent_style = space
indent_size = 2

[web/**]
indent_style = tab

[web/**/*.{json,md}]
indent_style = space
indent_size = 2

[package.json]
indent_style = space
indent_size = 2
