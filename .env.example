# --- Server ---
PORT=3000

# --- YouTube ---
YOUTUBE_API_KEY=

# --- OpenAI (production-style) ---
# Backend loads ONLY this file in the project root (same folder as index.js), not web/.env
# Put each variable on its own line. Do not append ENABLE_AI=... or any other assignment to OPENAI_API_KEY.
OPENAI_API_KEY=

# Explicit on (recommended). If omitted but OPENAI_API_KEY is set, the server defaults to enabled.
OPENAI_ENABLED=true

# Models (defaults shown)
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o

# Legacy: ENABLE_AI=true still enables OpenAI when the API key is set
# ENABLE_AI=true

# Dev-only: force heuristic analysis without calling OpenAI (explicit testing)
# OPENAI_DEV_MOCK=false

# Local sentiment layer (lexicon, runs before OpenAI). If every batch item is high-confidence,
# the batch can skip the OpenAI call (set to false to always call OpenAI when enabled).
# LOCAL_SENTIMENT_SHORT_CIRCUIT=true
# LOCAL_SENTIMENT_MIN_CONFIDENCE=0.58

# --- Daily token pools (UTC midnight reset). Totals = input + output tokens per pool per day. ---
OPENAI_MINI_POOL_SOFT_CAP=2000000
OPENAI_MINI_POOL_HARD_CAP=2300000
OPENAI_MINI_MAX_INPUT_TOKENS=10000
OPENAI_MINI_MAX_OUTPUT_TOKENS=1500

OPENAI_LARGE_POOL_SOFT_CAP=80000
OPENAI_LARGE_POOL_HARD_CAP=120000
OPENAI_LARGE_MAX_INPUT_TOKENS=4000
OPENAI_LARGE_MAX_OUTPUT_TOKENS=800

# --- Scan caps: manual search ---
OPENAI_MANUAL_MAX_SEARCH_CANDIDATES=40
OPENAI_MANUAL_MAX_MATCHED_VIDEOS=15
OPENAI_MANUAL_MAX_COMMENTS_PER_VIDEO=15

# --- Scan caps: watchlist automation ---
OPENAI_WATCHLIST_MAX_SEARCH_CANDIDATES=30
OPENAI_WATCHLIST_MAX_MATCHED_VIDEOS=10
OPENAI_WATCHLIST_MAX_COMMENTS_PER_VIDEO=10

# --- Hard safety (both profiles) ---
OPENAI_SAFETY_MAX_VIDEOS=20
OPENAI_SAFETY_MAX_COMMENTS_PER_VIDEO=20
OPENAI_SAFETY_MAX_COMMENTS_TOTAL=250

# Log search pipeline counts to server console (query, pool sizes, cache hits). Set to 1 or true.
# ANALYZER_SEARCH_DEBUG=1

# --- Optional: CORS for the SPA ---
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
